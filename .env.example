# Voice & Vision Assistant — Environment Variable Template
# Copy to .env and fill in real values before running.
#
# Classification: SECRET = must be set for production
#                 CONFIG = optional, has safe defaults

# ===== REQUIRED SECRETS =====
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
DEEPGRAM_API_KEY=your_deepgram_api_key
OLLAMA_API_KEY=your_ollama_api_key
ELEVEN_API_KEY=your_elevenlabs_api_key
OLLAMA_VL_API_KEY=your_ollama_vl_api_key
TAVUS_API_KEY=your_tavus_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# ===== VISION CONFIG =====
VISION_PROVIDER=ollama
OLLAMA_VL_MODEL_ID=qwen3.5:397b-cloud

# ===== AVATAR CONFIG =====
ENABLE_AVATAR=false
TAVUS_REPLICA_ID=your_replica_id
TAVUS_PERSONA_ID=your_persona_id
TAVUS_AVATAR_NAME=ally-vision-avatar

# ===== QR / AR SCANNING =====
ENABLE_QR_SCANNING=true
QR_CACHE_ENABLED=true
QR_AUTO_DETECT=true

# ===== SPATIAL PERCEPTION =====
SPATIAL_PERCEPTION_ENABLED=true
SPATIAL_USE_YOLO=false
ENABLE_SEGMENTATION=true
ENABLE_DEPTH=true
# =========================================================================
# SECURITY
# =========================================================================
# Face embedding encryption (default: true for privacy)
FACE_ENCRYPTION_ENABLED=true
FACE_ENCRYPTION_KEY=       # set a strong key for at-rest encryption

# Debug endpoints (disabled in production)
DEBUG_ENDPOINTS_ENABLED=false
DEBUG_AUTH_TOKEN=           # required when DEBUG_ENDPOINTS_ENABLED=true

# Diagnostics / telemetry (opt-in)
DIAGNOSTICS_ENABLED=false