# LiveKit Configuration
LIVEKIT_URL=your_livekit_url
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Voice Agent APIs
DEEPGRAM_API_KEY=your_deepgram_api_key
OLLAMA_API_KEY=your_ollama_api_key
ELEVEN_API_KEY=your_eleven_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Vision Provider Configuration
# Options: "ollama"
VISION_PROVIDER=ollama

# Ollama API Configuration
OLLAMA_VL_API_KEY=your_ollama_api_key
OLLAMA_VL_MODEL_ID=ollama:qwen3-vl:235b-instruct-cloud

# Tavus virtual avatar configuration (optional)
ENABLE_AVATAR=false
TAVUS_API_KEY=your_tavus_api_key
TAVUS_REPLICA_ID=your_replica_id
TAVUS_PERSONA_ID=your_persona_id
TAVUS_AVATAR_NAME=ally-vision-avatar

# QR / AR Tag Scanning Configuration
ENABLE_QR_SCANNING=true
QR_CACHE_ENABLED=true
QR_AUTO_DETECT=true
QR_CACHE_TTL_SECONDS=86400
# QR_CACHE_DIR=       # leave empty for default (qr_cache/)

# =========================================================================
# MEMORY ENGINE CONFIGURATION (RAG)
# =========================================================================
MEMORY_ENABLED=true
MEMORY_RETENTION_DAYS=30
MEMORY_MAX_VECTORS=5000
MEMORY_INDEX_PATH=./data/memory_index/
MEMORY_ENCRYPTION=true
EMBEDDING_MODEL=qwen3-embedding:4b
RAG_K=5
MEMORY_LIGHT_MODE=

# Spatial Perception
SPATIAL_USE_YOLO=true
SPATIAL_USE_MIDAS=true
YOLO_MODEL_PATH=models/yolov8n.onnx
MIDAS_MODEL_PATH=models/midas_v21_small_256.onnx

# =========================================================================
# SECURITY
# =========================================================================
# Face embedding encryption (default: true for privacy)
FACE_ENCRYPTION_ENABLED=true
FACE_ENCRYPTION_KEY=       # set a strong key for at-rest encryption

# Debug endpoints (disabled in production)
DEBUG_ENDPOINTS_ENABLED=false
DEBUG_AUTH_TOKEN=           # required when DEBUG_ENDPOINTS_ENABLED=true

# Diagnostics / telemetry (opt-in)
DIAGNOSTICS_ENABLED=false