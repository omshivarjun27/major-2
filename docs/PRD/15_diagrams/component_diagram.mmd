graph TB
    subgraph Users["USERS"]
        BlindUser["Blind/VI User"]
    end

    subgraph Interface["INTERFACE LAYER"]
        LiveKit["LiveKit WebRTC<br/>(WebSocket/WebRTC)<br/>Port 8081"]
        REST["FastAPI REST<br/>(HTTP)<br/>Port 8000"]
    end

    subgraph Application["APPLICATION LAYER"]
        FrameOrch["FrameOrchestrator<br/>Per-frame fusion engine"]
        LiveFrameMgr["LiveFrameManager<br/>Frame buffer (deque)"]
        Debouncer["Debouncer<br/>Deduplication"]
        WorkerPool["WorkerPool<br/>ThreadPoolExecutor<br/>(VRAM-aware)"]
        PercPool["PerceptionWorkerPool<br/>Parallel GPU inference"]
        StreamTTS["StreamingTTSCoordinator<br/>Sentence buffering"]
        Watchdog["Watchdog<br/>Health monitor"]
        PipeMon["PipelineMonitor<br/>Metrics"]
    end

    subgraph Domain["DOMAIN LAYER"]
        subgraph VQA["VQA Engine"]
            Perception["PerceptionPipeline<br/>detect → segment → depth"]
            SceneGraph["SceneGraphBuilder<br/>Spatial relationships"]
            SpatialFuser["SpatialFuser<br/>Temporal tracking"]
            VQAReasoner["VQAReasoner<br/>LLM-based Q&A"]
            MicroNav["MicroNavFormatter<br/>TTS navigation cues"]
        end

        subgraph Vision["Vision"]
            VisualProc["VisualProcessor<br/>Image analysis"]
            SpatialNav["NavigationOutput<br/>Obstacle records"]
        end

        subgraph Speech["Speech"]
            VoiceRouter["VoiceRouter<br/>Intent detection"]
            TTSHandler["TTSHandler<br/>Voice output"]
        end

        subgraph Memory["Memory Engine (RAG)"]
            Ingest["MemoryIngester<br/>Multimodal ingest"]
            Embedder["OllamaEmbedder<br/>qwen3-embedding:4b (local GPU)"]
            Indexer["FAISSIndexer<br/>Vector search"]
            Retriever["MemoryRetriever<br/>Similarity search"]
            RAGReasoner["RAGReasoner<br/>Contextual Q&A"]
            LLMClient["LLMClient<br/>qwen3.5:cloud (Ollama)"]
        end

        subgraph OCR["OCR Engine"]
            OCRPipeline["OCRPipeline<br/>3-tier fallback"]
        end

        subgraph QR["QR/AR Engine"]
            QRScanner["QRScanner<br/>pyzbar/OpenCV"]
            QRDecoder["QRDecoder<br/>Content classifier"]
            CacheMgr["CacheManager<br/>Offline cache"]
        end

        subgraph Braille["Braille Engine"]
            BrailleOCR["BrailleOCR<br/>Capture → classify"]
        end

        subgraph Face["Face Engine"]
            FaceDetect["FaceDetector<br/>Detection + tracking"]
        end
    end

    subgraph Infra["INFRASTRUCTURE LAYER"]
        OllamaH["OllamaHandler<br/>HTTP → Ollama cloud runtime"]
        DeepgramA["Deepgram Plugin<br/>WebSocket STT"]
        ElevenA["ElevenLabs Plugin<br/>HTTP/WS TTS"]
        TavusA["TavusAdapter<br/>HTTP + WS Avatar"]
        InetSearch["InternetSearch<br/>DuckDuckGo"]
    end

    subgraph CloudSvc["CLOUD SERVICES"]
        QwenCloud["qwen3.5:cloud<br/>(LLM inference via Ollama cloud runtime)"]
        DeepgramAPI["Deepgram<br/>(cloud STT)"]
        ElevenAPI["ElevenLabs<br/>(cloud TTS)"]
        TavusAPI["Tavus<br/>(cloud avatar)"]
        LiveKitAPI["LiveKit<br/>(real-time transport)"]
        DDG["DuckDuckGo<br/>(web search)"]
    end

    subgraph LocalGPU["LOCAL GPU SERVICES"]
        OllamaLocal["qwen3-embedding:4b<br/>(Ollama local embedding, GPU)"]
        YOLOModel["YOLO Detector<br/>(ONNX Runtime CUDA EP)"]
        MiDaSModel["MiDaS Depth<br/>(ONNX Runtime CUDA EP)"]
        OCRModels["OCR Models<br/>(EasyOCR/Tesseract)"]
        FaceModel["Face Detection<br/>(PyTorch CUDA)"]
        QRDecode["QR Decoding<br/>(pyzbar/OpenCV)"]
    end

    subgraph Storage["STORAGE"]
        FAISS["FAISS Index<br/>data/memory_index/"]
        QRCache["QR Cache<br/>qr_cache/"]
        Models["ONNX Models<br/>models/"]
        Config["config.yaml<br/>configs/"]
    end

    %% Users → Interface
    BlindUser -->|"Voice + Camera"| LiveKit
    BlindUser -->|"HTTP requests"| REST

    %% Interface → Application
    LiveKit -->|"Audio/Video frames"| FrameOrch
    REST -->|"HTTP requests"| FrameOrch

    %% Application → Domain
    FrameOrch -->|"parallel tasks"| PercPool
    PercPool -->|"detection"| Perception
    PercPool -->|"OCR"| OCRPipeline
    FrameOrch -->|"fused result"| SceneGraph
    SceneGraph -->|"scene data"| SpatialFuser
    SpatialFuser -->|"obstacles"| MicroNav
    VoiceRouter -->|"visual intent"| VQAReasoner
    VoiceRouter -->|"spatial intent"| SpatialFuser

    %% Domain → Cloud Services
    LLMClient -->|"LLM reasoning<br/>(async HTTP)"| OllamaH
    OllamaH -->|"HTTP POST<br/>(async)"| QwenCloud
    DeepgramA -->|"WebSocket<br/>(async streaming)"| DeepgramAPI
    ElevenA -->|"HTTP/WS<br/>(async streaming)"| ElevenAPI
    TavusA -->|"HTTP + WS<br/>(async)"| TavusAPI
    InetSearch -->|"HTTP<br/>(async)"| DDG

    %% Domain → Local GPU Services
    Embedder -->|"embed text<br/>(GPU batch)"| OllamaLocal
    Perception -->|"detect objects"| YOLOModel
    Perception -->|"estimate depth"| MiDaSModel
    OCRPipeline -->|"text recognition"| OCRModels
    FaceDetect -->|"face inference"| FaceModel
    QRScanner -->|"decode"| QRDecode

    %% Domain → Storage
    Indexer -->|"persist"| FAISS
    CacheMgr -->|"read/write"| QRCache
    Perception -->|"load weights"| Models

    %% Monitoring
    Watchdog -.->|"health checks"| FrameOrch
    PipeMon -.->|"metrics"| PercPool
    Debouncer -.->|"dedup"| FrameOrch

    %% Styling
    classDef cloud fill:#fff3e0,stroke:#ff9800
    classDef localgpu fill:#e8eaf6,stroke:#3f51b5
    classDef storage fill:#e8f5e9,stroke:#4caf50
    classDef domain fill:#e3f2fd,stroke:#2196f3
    classDef infra fill:#fce4ec,stroke:#e91e63
    classDef app fill:#f3e5f5,stroke:#9c27b0

    class QwenCloud,DeepgramAPI,ElevenAPI,TavusAPI,LiveKitAPI,DDG cloud
    class OllamaLocal,YOLOModel,MiDaSModel,OCRModels,FaceModel,QRDecode localgpu
    class FAISS,QRCache,Models,Config storage
    class OllamaH,DeepgramA,ElevenA,TavusA,InetSearch infra
