{
  "ErrorEnvelope": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["error"] },
      "error": {
        "type": "object",
        "required": ["code", "message", "layer", "retryable"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "layer": { "type": "string", "enum": ["interface", "application", "domain", "local_gpu", "cloud", "storage"] },
          "retryable": { "type": "boolean" }
        }
      }
    }
  },
  "error_codes": [
    {
      "code": "VALIDATION_ERROR",
      "layer": "interface",
      "retryable": false,
      "http_status": 400,
      "description": "Request body fails Pydantic validation"
    },
    {
      "code": "GPU_MEMORY_EXCEEDED",
      "layer": "local_gpu",
      "retryable": true,
      "http_status": 503,
      "description": "VRAM exhausted on RTX 4060 (8GB limit)"
    },
    {
      "code": "CLOUD_TIMEOUT",
      "layer": "cloud",
      "retryable": true,
      "http_status": 504,
      "description": "Cloud service (qwen3.5:cloud, Deepgram, ElevenLabs) did not respond within deadline"
    },
    {
      "code": "CLOUD_RATE_LIMIT",
      "layer": "cloud",
      "retryable": true,
      "http_status": 429,
      "description": "Cloud service rate limit exceeded"
    },
    {
      "code": "MODEL_UNAVAILABLE",
      "layer": "local_gpu",
      "retryable": true,
      "http_status": 503,
      "description": "Local model (YOLO, MiDaS, EasyOCR, qwen3-embedding:4b) failed to load"
    },
    {
      "code": "INTERNAL_ERROR",
      "layer": "application",
      "retryable": false,
      "http_status": 500,
      "description": "Unhandled exception in application layer"
    },
    {
      "code": "SERVICE_UNAVAILABLE",
      "layer": "domain",
      "retryable": true,
      "http_status": 503,
      "description": "Required service component is offline or not ready"
    }
  ]
}
