%% deployment.mmd — Deployment & Infrastructure Diagram
%% Voice & Vision Assistant for Blind
%% Render at: https://mermaid.live

flowchart LR
    subgraph USER["End Users"]
        BU(["Blind User\nmic + camera"])
        SU(["Sighted User\nvideo call"])
    end

    subgraph CLOUD_EXT["Cloud External Services"]
        direction TB
        LK_CLOUD["LiveKit Cloud\nWebRTC SFU"]
        DG_CLOUD["Deepgram API\nSTT gRPC"]
        EL_CLOUD["ElevenLabs API\nTTS HTTPS"]
        OL_CLOUD["Ollama Server\nqwen3.5:397b-cloud\n:11434"]
        DDG_CLOUD["DuckDuckGo\nHTTPS"]
        TAV_CLOUD["Tavus API\nREST+WS (optional)"]
    end

    subgraph CONTAINER["Docker Container\npython:3.11-slim / appuser (non-root)"]
        direction TB

        subgraph PROC["Processes"]
            direction LR
            UVICORN["uvicorn\nFastAPI :8000\napps/api/server.py"]
            AGENT_P["livekit-agents worker\n:8081\napps/realtime/entrypoint.py"]
        end

        subgraph FS["Container Filesystem"]
            direction LR
            CODE["source code\ncore/ application/\ninfrastructure/ shared/\napps/"]
            MODELS_F["models/\nyolov8n.onnx\nmidas_v21_small_256.onnx"]
            DATA_F["data/\nSQLite memory.db\nFAISS index\nqr_cache/"]
            RUNTIME_F[".runtime/\nlogs/ cache/"]
        end

        HC["HEALTHCHECK\nGET /health\nevery 30s"]
    end

    subgraph OBS_STACK["Observability Stack (Compose)"]
        direction TB
        PROM_S["Prometheus :9090\nscrape interval 10s"]
        GRAF_S["Grafana :3000\ndashboards"]
        LOKI_S["Loki :3100\nlog aggregation"]
        ALERT_S["Alertmanager :9093\nalert_rules.yml"]
        NODE_EXP["Node Exporter :9100\nhost metrics (opt)"]
        GPU_EXP["NVIDIA Exporter :9445\nGPU metrics (opt)"]
    end

    subgraph CI["GitHub Actions CI/CD"]
        direction TB
        GH_CI["ci.yml\nsecrets-scan→test(3.10/11/12)\n→lint→sast→dep-scan→docker"]
        GH_STAGING["deploy-staging.yml\ntagged release trigger"]
        GH_PROD["deploy-production.yml\nmanual approval gate\ncanary/ rollout"]
    end

    %% User flows
    BU -- "WebRTC audio/video" --> LK_CLOUD
    SU -- "WebRTC" --> LK_CLOUD

    %% Container ↔ External
    AGENT_P -- "livekit-agents SDK\nWebRTC" --> LK_CLOUD
    AGENT_P -- "gRPC plugin" --> DG_CLOUD
    AGENT_P -- "HTTPS chunks" --> EL_CLOUD
    AGENT_P -- "HTTP REST SSE" --> OL_CLOUD
    AGENT_P -- "HTTPS" --> DDG_CLOUD
    AGENT_P -- "REST+WS" --> TAV_CLOUD
    UVICORN -- "HTTP REST" --> OL_CLOUD

    %% Internal wiring
    UVICORN --- CODE
    AGENT_P --- CODE
    CODE --- MODELS_F
    CODE --- DATA_F
    CODE --- RUNTIME_F

    %% Observability scraping
    PROM_S -- "scrape :8000/metrics" --> UVICORN
    PROM_S -- "scrape :8081/metrics" --> AGENT_P
    PROM_S -- "scrape :9100" --> NODE_EXP
    PROM_S -- "scrape :9445" --> GPU_EXP
    PROM_S --> GRAF_S
    PROM_S --> ALERT_S
    AGENT_P -- "JSON push" --> LOKI_S
    LOKI_S --> GRAF_S

    %% CI/CD
    GH_CI --> GH_STAGING
    GH_STAGING --> GH_PROD
    GH_PROD -. "deploy image" .-> CONTAINER

    classDef user fill:#f0f5ff,stroke:#2f54eb
    classDef ext fill:#fff1f0,stroke:#f5222d
    classDef proc fill:#e6f7ff,stroke:#1890ff
    classDef fs fill:#fff7e6,stroke:#fa8c16
    classDef obs fill:#f9f0ff,stroke:#722ed1
    classDef ci fill:#f6ffed,stroke:#52c41a

    class BU,SU user
    class LK_CLOUD,DG_CLOUD,EL_CLOUD,OL_CLOUD,DDG_CLOUD,TAV_CLOUD ext
    class UVICORN,AGENT_P proc
    class CODE,MODELS_F,DATA_F,RUNTIME_F fs
    class PROM_S,GRAF_S,LOKI_S,ALERT_S,NODE_EXP,GPU_EXP obs
    class GH_CI,GH_STAGING,GH_PROD ci
